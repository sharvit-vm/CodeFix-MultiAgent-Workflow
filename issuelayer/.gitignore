# ── Virtual environment ────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment variables — NEVER commit these ─────────────────────────────────
.env
*.env

# ── Python cache ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ── Data / queue files — runtime generated ─────────────────────────────────────
data/
*.json

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/

# ── VS Code ────────────────────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── OS files ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Testing ────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Build ──────────────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/